<?xml version="1.0" encoding="UTF-8"?>
<scenario>
    <meta>
        <scenario_id>S003</scenario_id>
        <test_id>T003</test_id>
        <flight_phase_code>P03</flight_phase_code>
        <flight_phase_name>Cruise</flight_phase_name>
        <weather_code>W03</weather_code>
        <weather_name>Crosswind</weather_name>
        <mode>Nominal</mode>
        <description>Steady-state cruise with a directional crosswind, no injected faults.</description>
    </meta>

    <aircraft>
        <aircraft_id>c172p</aircraft_id>
        <fdm>jsbsim</fdm>
    </aircraft>

    <initial_conditions>
        <airport>KSFO</airport>
        <runway>28L</runway>
        <altitude_ft>6500</altitude_ft>
        <airspeed_kt>110</airspeed_kt>
        <heading_deg>90</heading_deg>
        <on_ground>false</on_ground>
    </initial_conditions>

    <environment>
        <wind_speed_kt>15</wind_speed_kt>
        <wind_dir_deg>0</wind_dir_deg>
        <turbulence_norm>0.15</turbulence_norm>
        <visibility_m>9000</visibility_m>
        <precipitation>none</precipitation>
        <cloud_layer>scattered</cloud_layer>
    </environment>

    <fault_injection enabled="false">
        <type>none</type>
        <target_subsystem/>
        <severity_norm>0.0</severity_norm>
    </fault_injection>

    <run_parameters>
        <duration_sec>90</duration_sec>
        <telemetry_rate_hz>10</telemetry_rate_hz>
    </run_parameters>
</scenario>
