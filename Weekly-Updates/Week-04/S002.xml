<?xml version="1.0" encoding="UTF-8"?>
<scenario>
    <meta>
        <scenario_id>S002</scenario_id>
        <test_id>T002</test_id>
        <flight_phase_code>P02</flight_phase_code>
        <flight_phase_name>Climb</flight_phase_name>
        <weather_code>W02</weather_code>
        <weather_name>Light wind</weather_name>
        <mode>Nominal</mode>
        <description>Initial climb-out under light steady wind, no injected faults.</description>
    </meta>

    <aircraft>
        <aircraft_id>c172p</aircraft_id>
        <fdm>jsbsim</fdm>
    </aircraft>

    <initial_conditions>
        <airport>KSFO</airport>
        <runway>28L</runway>
        <altitude_ft>1500</altitude_ft>
        <airspeed_kt>80</airspeed_kt>
        <heading_deg>280</heading_deg>
        <on_ground>false</on_ground>
    </initial_conditions>

    <environment>
        <wind_speed_kt>8</wind_speed_kt>
        <wind_dir_deg>270</wind_dir_deg>
        <turbulence_norm>0.1</turbulence_norm>
        <visibility_m>10000</visibility_m>
        <precipitation>none</precipitation>
        <cloud_layer>few</cloud_layer>
    </environment>

    <fault_injection enabled="false">
        <type>none</type>
        <target_subsystem/>
        <severity_norm>0.0</severity_norm>
    </fault_injection>

    <run_parameters>
        <duration_sec>90</duration_sec>
        <telemetry_rate_hz>10</telemetry_rate_hz>
    </run_parameters>
</scenario>
