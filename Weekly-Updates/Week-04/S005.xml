<?xml version="1.0" encoding="UTF-8"?>
<scenario>
    <meta>
        <scenario_id>S005</scenario_id>
        <test_id>T005</test_id>
        <flight_phase_code>P07</flight_phase_code>
        <flight_phase_name>Landing</flight_phase_name>
        <weather_code>W05</weather_code>
        <weather_name>Low visibility/Rain</weather_name>
        <mode>Faulted</mode>
        <description>Landing roll under reduced visibility and precipitation with injected braking degradation.</description>
    </meta>

    <aircraft>
        <aircraft_id>c172p</aircraft_id>
        <fdm>jsbsim</fdm>
    </aircraft>

    <initial_conditions>
        <airport>KSFO</airport>
        <runway>28L</runway>
        <altitude_ft>50</altitude_ft>
        <airspeed_kt>65</airspeed_kt>
        <heading_deg>280</heading_deg>
        <on_ground>false</on_ground>
    </initial_conditions>

    <environment>
        <wind_speed_kt>10</wind_speed_kt>
        <wind_dir_deg>260</wind_dir_deg>
        <turbulence_norm>0.2</turbulence_norm>
        <visibility_m>1600</visibility_m>
        <precipitation>rain</precipitation>
        <cloud_layer>overcast</cloud_layer>
    </environment>

    <fault_injection enabled="true">
        <type>braking_degradation</type>
        <target_subsystem>landing_gear</target_subsystem>
        <severity_norm>0.4</severity_norm>
    </fault_injection>

    <run_parameters>
        <duration_sec>90</duration_sec>
        <telemetry_rate_hz>10</telemetry_rate_hz>
    </run_parameters>
</scenario>
